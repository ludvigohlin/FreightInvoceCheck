# Freight Invoice Control — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Claude API (optional) ─────────────────────────────────────────────────────
# Set USE_CLAUDE_API=true to enable AI classification, summaries, and anomaly explanations.
# Claude is NOT used for financial calculations. Default: false (deterministic only).
ANTHROPIC_API_KEY=your_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
USE_CLAUDE_API=false

# ── File behaviour ────────────────────────────────────────────────────────────
# Set to true to copy processed files from 00_Inbox to 01_Raw after processing.
MOVE_FILES_AFTER_PROCESSING=false
